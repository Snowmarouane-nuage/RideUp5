{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "build": {
    "env": {
      "DISABLE_ESLINT_PLUGIN": "true",
      "REACT_APP_SITE_URL": "https://ride-up5-swhv.vercel.app",
      "REACT_APP_DIRECT_API_URL": "https://rideup5-production.up.railway.app"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://rideup5-production.up.railway.app/api"
    },
    {
      "source": "/api/",
      "destination": "https://rideup5-production.up.railway.app/api/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://rideup5-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
